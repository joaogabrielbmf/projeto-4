{
  "name": "todo-app",
  "version": "1.0.0",
  "description": "Todo App with Cypress tests",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "test:backend": "node backend/tests/api.test.js",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "cypress:frontend": "cypress run --spec 'cypress/e2e/frontend.cy.js'",
    "cypress:backend": "cypress run --spec 'cypress/e2e/backend.cy.js'"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "cypress": "^15.16.0",
    "nodemon": "^3.0.2",
    "wait-on": "^7.2.0"
  }
}
